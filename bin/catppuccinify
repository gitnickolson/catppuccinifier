#!/usr/bin/env ruby
# frozen_string_literal: true

require 'zeitwerk'

loader = Zeitwerk::Loader.new
loader.push_dir(File.expand_path('../lib', __dir__))
loader.setup

filepath = Utility::InputFetcher.fetch_filepath
theme_name = Utility::InputFetcher.fetch_theme

catppuccinifier = Catppuccinifier.new(theme_name:)
catppuccinifier.catppuccinify(filepath:)
